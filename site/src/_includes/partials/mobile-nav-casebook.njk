<nav id="mobile-nav" class="mobile-nav--casebook" aria-label="Casebook navigation">
  <div class="mobile-nav-header">
    <a href="{{ '/cases/' | url }}" class="nav-logo casebook-header__logo"
       aria-label="{{ site.name | default('The Frontend Casebook') }}, home">
      <span>{ }</span> Casebook
    </a>
    <button id="mobile-nav-close" class="mobile-nav-close" type="button" aria-label="Close menu">
      <svg class="icon-lg" aria-hidden="true"><use href="#i-close"/></svg>
    </button>
  </div>
  <ul class="mobile-nav-links">
    <li>
      <a href="{{ '/cases/' | url }}"{% if navActive == 'cases' %} aria-current="page"{% endif %}>Cases</a>
    </li>
    <li>
      <a href="{{ '/about/' | url }}"{% if navActive == 'about' %} aria-current="page"{% endif %}>About</a>
    </li>
    <li><a href="/">Portfolio</a></li>
  </ul>
  <div class="mobile-nav-footer">
    <p class="mobile-nav-footer__label">Preferences</p>
    <div class="mobile-nav-prefs">
      <div class="prefs-cell">
        <span class="prefs-cell-label">Language</span>
        <div class="theme-picker lang-picker">
          <button type="button" class="lang-pick-btn" id="lang-pick-btn-mobile-cb"
                  aria-expanded="false" aria-controls="lang-menu-mobile-cb"
                  aria-label="Language: EN. Change">
            <svg class="icon-sm" aria-hidden="true"><use href="#i-globe"/></svg>
            <span class="lang-pick-label">EN</span>
          </button>
          <ul id="lang-menu-mobile-cb" class="theme-menu lang-menu prefs-menu"
              role="listbox" aria-label="Choose language" hidden data-popover-fixed="true">
            <li class="theme-menu-item lang-menu-item" role="option" data-l="en" aria-selected="true" tabindex="-1">English</li>
            <li class="theme-menu-item lang-menu-item" role="option" data-l="hi" tabindex="-1">हिन्दी</li>
            <li class="theme-menu-item lang-menu-item" role="option" data-l="es" tabindex="-1">Español</li>
          </ul>
        </div>
      </div>
      <div class="prefs-cell">
        <span class="prefs-cell-label">Theme</span>
        <div class="theme-picker">
          <button type="button" class="theme-pick-btn" id="theme-pick-btn-mobile-cb"
                  aria-expanded="false" aria-controls="theme-menu-mobile-cb"
                  aria-label="Theme: High contrast. Change">
            <svg class="icon-sm" aria-hidden="true"><use href="#i-palette"/></svg>
          </button>
          <ul id="theme-menu-mobile-cb" class="theme-menu prefs-menu"
              role="listbox" aria-label="Choose theme" hidden data-popover-fixed="true">
            <li class="theme-menu-item" role="option" data-t="high-contrast" aria-selected="true" tabindex="-1"><span class="theme-swatch ts-high-contrast" aria-hidden="true"></span>High contrast</li>
            <li class="theme-menu-item" role="option" data-t="light" tabindex="-1"><span class="theme-swatch ts-light" aria-hidden="true"></span>Warm paper</li>
            <li class="theme-menu-item" role="option" data-t="dark" tabindex="-1"><span class="theme-swatch ts-dark" aria-hidden="true"></span>Charcoal</li>
            <li class="theme-menu-item" role="option" data-t="sage" tabindex="-1"><span class="theme-swatch ts-sage" aria-hidden="true"></span>Sage mist</li>
            <li class="theme-menu-item" role="option" data-t="slate" tabindex="-1"><span class="theme-swatch ts-slate" aria-hidden="true"></span>Slate studio</li>
            <li class="theme-menu-item" role="option" data-t="dusk" tabindex="-1"><span class="theme-swatch ts-dusk" aria-hidden="true"></span>Dusk editorial</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="mobile-nav-footer__casey" data-casey-prefs-root>
      {% include "partials/casey-companion-prefs.njk" %}
    </div>
  </div>
</nav>
