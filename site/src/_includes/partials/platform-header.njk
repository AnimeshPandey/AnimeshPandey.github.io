{# Unified platform header — portfolio + casebook #}
{% set product = product | default('portfolio-home') %}
{% set homeHref = homeHref | default('/') %}
{% set showRecruiter = showRecruiter | default(true) %}
{% set showSectionDropdown = showSectionDropdown | default(product == 'portfolio-home') %}
{% set navActive = navActive | default('') %}

<header class="platform-header{% if product == 'casebook' %} platform-header--casebook{% endif %}">
  <div class="nav-inner">
    {% if product == 'casebook' %}
    <a href="{{ '/cases/' | url }}" class="nav-logo casebook-header__logo" aria-label="{{ site.name | default('The Frontend Casebook') }}, home">
      <span>{ }</span> Casebook
    </a>
    <nav class="platform-header__nav" aria-label="Casebook navigation">
      <ul class="casebook-header__nav" role="list">
        <li><a href="{{ '/cases/' | url }}"{% if navActive == 'cases' %} aria-current="page"{% endif %}>Cases</a></li>
        <li><a href="{{ '/about/' | url }}"{% if navActive == 'about' %} aria-current="page"{% endif %}>About</a></li>
        <li><a href="{{ '/account/' | url }}"{% if navActive == 'account' %} aria-current="page"{% endif %} data-casebook-auth-label>Sign in</a></li>
        <li><a href="/">Portfolio</a></li>
      </ul>
    </nav>
    {% else %}
    <a href="{{ homeHref }}{% if product == 'portfolio-home' %}#hero{% endif %}" class="nav-logo" data-i18n-attr="aria-label" data-i18n="a11y.home">AP<span>.</span></a>
    {% endif %}

    <div class="nav-right">
      {% if showSectionDropdown %}
      <div class="nav-sections nav-sections--desktop">
        <button type="button" class="nav-sections__btn" id="nav-sections-btn"
                aria-expanded="false" aria-controls="nav-sections-menu"
                data-i18n-attr="aria-label" data-i18n="nav.sections">Sections</button>
        <ul id="nav-sections-menu" class="nav-sections__menu prefs-menu" role="menu" hidden>
          <li role="none"><a href="#about" role="menuitem" data-i18n="nav.about">about</a></li>
          <li role="none"><a href="#experience" role="menuitem" data-i18n="nav.experience">experience</a></li>
          <li role="none"><a href="#skills" role="menuitem" data-i18n="nav.skills">skills</a></li>
          <li role="none"><a href="#projects" role="menuitem" data-i18n="nav.projects">projects</a></li>
          <li role="none"><a href="#writing" role="menuitem" data-i18n="nav.writing">writing</a></li>
          <li role="none"><a href="#contact" role="menuitem" data-i18n="nav.contact">contact</a></li>
        </ul>
      </div>
      {% endif %}

      <div class="nav-utilities">
        {% if product == 'casebook' %}
        {% include "partials/casebook-preferences.njk" %}
        <div class="casebook-prefs">
          <button type="button" class="casebook-prefs__trigger casey-panel__trigger platform-icon-btn" id="casebook-prefs-btn"
                  aria-expanded="false" aria-controls="casebook-prefs-menu"
                  aria-haspopup="dialog"
                  aria-label="Casey guide settings">
            <img class="casey-panel__trigger-img" src="{{ '/assets/casey/junior/idle.png' | url }}?v=__AP_BUILD_ID__" width="24" height="24" alt="" data-casey-trigger-avatar aria-hidden="true" />
            <span class="casebook-prefs__trigger-label">Casey</span>
          </button>
          <div id="casebook-prefs-menu" class="casebook-prefs__menu casey-panel__menu prefs-menu" role="dialog" aria-label="Casey guide settings" hidden>
            {% include "partials/casey-companion-prefs.njk" %}
          </div>
        </div>
        {% else %}
        <div class="theme-picker">
          <button type="button" class="theme-pick-btn platform-icon-btn" id="theme-pick-btn-header"
                  aria-label="Theme: High contrast. Change" aria-expanded="false" aria-controls="theme-menu-header">
            <svg class="icon-sm" aria-hidden="true"><use href="#i-palette"/></svg>
          </button>
          <ul id="theme-menu-header" class="theme-menu prefs-menu" role="listbox" aria-label="Choose theme" hidden>
            <li class="theme-menu-item" role="option" data-t="high-contrast" aria-selected="true" tabindex="-1"><span class="theme-swatch ts-high-contrast" aria-hidden="true"></span>High contrast</li>
            <li class="theme-menu-item" role="option" data-t="light" tabindex="-1"><span class="theme-swatch ts-light" aria-hidden="true"></span>Warm paper</li>
            <li class="theme-menu-item" role="option" data-t="dark" tabindex="-1"><span class="theme-swatch ts-dark" aria-hidden="true"></span>Charcoal</li>
            <li class="theme-menu-item" role="option" data-t="sage" tabindex="-1"><span class="theme-swatch ts-sage" aria-hidden="true"></span>Sage mist</li>
            <li class="theme-menu-item" role="option" data-t="slate" tabindex="-1"><span class="theme-swatch ts-slate" aria-hidden="true"></span>Slate studio</li>
            <li class="theme-menu-item" role="option" data-t="dusk" tabindex="-1"><span class="theme-swatch ts-dusk" aria-hidden="true"></span>Dusk editorial</li>
          </ul>
        </div>
        <div class="theme-picker lang-picker">
          <button type="button" class="lang-pick-btn platform-icon-btn" id="lang-pick-btn-header"
                  aria-label="Language: EN. Change" aria-expanded="false" aria-controls="lang-menu-header">
            <svg class="icon-sm" aria-hidden="true"><use href="#i-globe"/></svg>
            <span class="lang-pick-label" aria-hidden="true">EN</span>
          </button>
          <ul id="lang-menu-header" class="theme-menu lang-menu prefs-menu" role="listbox" aria-label="Choose language" hidden>
            <li class="theme-menu-item lang-menu-item" role="option" data-l="en" aria-selected="true" tabindex="-1">English</li>
            <li class="theme-menu-item lang-menu-item" role="option" data-l="hi" tabindex="-1">हिन्दी</li>
            <li class="theme-menu-item lang-menu-item" role="option" data-l="es" tabindex="-1">Español</li>
          </ul>
        </div>
        <button type="button" class="nav-resume-icon platform-icon-btn" id="nav-resume-preview"
                aria-haspopup="dialog" data-i18n-attr="aria-label" data-i18n="a11y.previewResume"
                aria-label="Preview resume">
          <svg class="icon-sm" aria-hidden="true"><use href="#i-download"/></svg>
          <span class="visually-hidden" data-i18n="nav.resume">Resume</span>
        </button>
        {% endif %}
      </div>

      <button id="hamburger" class="hamburger platform-icon-btn" aria-expanded="false" aria-controls="mobile-nav"
              aria-label="{% if product == 'casebook' %}Open Casebook menu{% else %}Open menu{% endif %}">
        <svg class="icon-lg" aria-hidden="true"><use href="#i-menu"/></svg>
      </button>
    </div>
  </div>
</header>

<div id="nav-overlay" aria-hidden="true"></div>
{% if product == 'casebook' %}
{% include "partials/mobile-nav-casebook.njk" %}
{% else %}
{% include "partials/mobile-nav.njk" %}
{% endif %}
