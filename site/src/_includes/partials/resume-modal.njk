<dialog id="resume-preview" class="resume-modal" aria-labelledby="resume-modal-title">
  <div class="resume-modal-inner">
    <div class="resume-modal-head">
      <h2 id="resume-modal-title" class="resume-modal-title" data-i18n="resume.modalTitle">Animesh Pandey — Resume</h2>
      <div class="resume-modal-actions">
        <a href="/resume.pdf" download="Animesh_Pandey_Resume.pdf" class="btn btn-outline resume-modal-dl" data-i18n-attr="aria-label" data-i18n="resume.downloadPdf">
          <svg class="icon-sm" aria-hidden="true"><use href="#i-download"/></svg>
          Download PDF
        </a>
        <button type="button" class="resume-modal-close" data-i18n-attr="aria-label" data-i18n="resume.closePreview">
          <svg class="icon-lg" aria-hidden="true"><use href="#i-close"/></svg>
        </button>
      </div>
    </div>
    <div class="resume-modal-body">
      <!-- src set lazily by nav.js on first open — an eager PDF embed disables the whole page's back/forward cache eligibility -->
      <iframe data-src="/resume.pdf#view=FitH&amp;toolbar=0&amp;navpanes=0" class="resume-embed" title="Resume PDF preview"></iframe>
      <div class="resume-embed-fallback" hidden>
        <p data-i18n="resume.fallbackText">PDF preview isn't available in this browser.</p>
        <a href="/resume.pdf" download="Animesh_Pandey_Resume.pdf" class="btn btn-dark">
          <svg class="icon-sm" aria-hidden="true"><use href="#i-download"/></svg>
          <span data-i18n="resume.fallbackDownload">Download PDF instead</span>
        </a>
      </div>
    </div>
  </div>
</dialog>
