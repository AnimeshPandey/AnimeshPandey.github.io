<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <script>
  (function(){var v=['light','dark','sage','slate','dusk','high-contrast'];var t=localStorage.getItem('theme');document.documentElement.dataset.theme=v.indexOf(t)!==-1?t:'light';var l=localStorage.getItem('locale');if(l)document.documentElement.lang=l;})();
  </script>
  <title>{{ title }} · Animesh Pandey</title>
  <meta name="description" content="{{ description }}" />
  <meta name="author" content="Animesh Pandey" />
  <meta name="robots" content="{{ 'noindex' if noindex else 'index, follow' }}" />
  <meta name="theme-color" content="#FAF8F4" />
  {% if canonical %}<link rel="canonical" href="{{ canonical }}" />{% endif %}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/site.webmanifest" />
  {% include "partials/platform-fonts.njk" %}
  {% set product = 'portfolio-article' %}
  {% set productStylesheet = '/assets/site.css' %}
  {% include "partials/platform-shell-styles.njk" %}
  {% if structuredData %}{{ structuredData | safe }}{% endif %}
</head>
<body>
{% include "partials/icon-sprite-nav.njk" %}
<a class="platform-skip skip-link" href="#article-content" data-i18n="a11y.skipToArticle">Skip to article</a>
{% set homeHref = '/' %}
{% set showRecruiter = false %}
{% include "partials/site-header.njk" %}
{{ content | safe }}
<footer>
  <div class="foot-inner">
    <div class="foot-l" data-i18n="footer.location">Animesh Pandey · Bangalore, India</div>
    <a href="/" class="article-footer-link" data-i18n="footer.backHome">← anmshpndy.com</a>
  </div>
</footer>
{% include "partials/resume-modal.njk" %}
{% include "partials/site-scripts.njk" %}
<script defer src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon='{"token": "YOUR_CF_BEACON_TOKEN"}'></script>
</body>
</html>
