{# ── case-footer.njk ── Growth.Design credit + byline ── #}
<footer class="casebook-case-footer" style="margin-top: 40px; padding-top: 20px; border-top: 1px solid var(--casebook-border);">
  <p style="font-family: var(--mono, monospace); font-size: 11px; color: var(--casebook-ink-faint);">
    The Frontend Casebook · by
    <a href="{{ site.author.url }}" style="color: var(--casebook-accent-ink);">{{ site.author.name }}</a>
  </p>
  <p class="case-format-credit" style="font-size: 11px; color: var(--casebook-ink-faint); margin-top: 4px;">
    Story format inspired by
    <a href="https://growth.design/case-studies/" rel="noopener noreferrer"
       style="color: var(--casebook-ink-faint);">Growth.Design case studies</a>.
  </p>
</footer>
