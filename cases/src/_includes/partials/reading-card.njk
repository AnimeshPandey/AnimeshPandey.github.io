{#
  reading-card.njk — reading-room entry card
  Context: entry (from library-entries.json)
#}
<article class="reading-card"
         data-locale="{{ entry.locale }}"
         data-company="{{ entry.companySlug }}"
         data-year="{{ entry.publishedYear }}"
         {% for cat in entry.categories %}data-cat-{{ cat }}="true" {% endfor %}
         data-track="{{ entry.track }}"
         data-priority="{{ entry.priority }}">

  <header class="reading-card__header">
    {# Real catalog number — this entry's actual 1-based position in the
       library's canonical order (entry.catalogNo, stamped once onto each
       entry object in .eleventy.js), not a fabricated count or a loop-local
       index. This partial is also included from the company page's
       filtered + re-sorted subset, where the ambient loop index would show
       a different "No." for the same entry than the one on /library/, so
       the real position travels with the entry object instead. Same "real
       number, not decoration" idiom as the hub's case stamp, styled for a
       card-catalog rather than a case-file. #}
    <span class="reading-card__catalog-no" aria-hidden="true">No. {{ entry.catalogNo | pad3 }}</span>
    {% if entry.company %}
      <span class="reading-card__company-chip">{{ entry.company }}</span>
    {% endif %}
    {% if entry.publishedYear %}
      <span class="reading-card__year-chip">{{ entry.publishedYear }}</span>
    {% endif %}
    {% for cat in entry.categories %}
      <span class="reading-card__cat-chip reading-card__cat-chip--{{ cat }}">{{ cat | replace("-", " ") }}</span>
    {% endfor %}
  </header>

  <h3 class="reading-card__title">
    <a href="{{ entry.primaryUrl }}"
       target="_blank"
       rel="noopener noreferrer"
       class="reading-card__link">
      {{ entry.title }}
      <svg class="reading-card__external-icon" aria-hidden="true" focusable="false"
           width="12" height="12" viewBox="0 0 12 12" fill="none"
           xmlns="http://www.w3.org/2000/svg">
        <path d="M10 2L2 10M10 2H6M10 2V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </h3>

  {% if entry.mapsToSlug %}
    {# Cross-reference the real case number already shown on that case's hub
       card and cover (cases/lib/case-navigation.js's liveIndex) — the same
       live-case ordering, not a separate count. #}
    {% set mappedNav = entry.mapsToSlug | caseNav %}
    <p class="reading-card__ours reading-card__ours--linked">
      <a href="{{ ('/' ~ entry.mapsToSlug ~ '/') | url }}">
        Casebook version available{% if mappedNav %} <span class="reading-card__case-ref">· Case No. {{ mappedNav.liveIndex | pad3 }}</span>{% endif %} →
      </a>
    </p>
  {% else %}
    <p class="reading-card__ours reading-card__ours--coming">Our take coming</p>
  {% endif %}

  {% if entry.frontendcsUrl %}
    <footer class="reading-card__footer">
      <a href="{{ entry.frontendcsUrl }}"
         target="_blank"
         rel="noopener noreferrer"
         class="reading-card__fcs-link">
        frontendcs.com →
      </a>
    </footer>
  {% endif %}

</article>
