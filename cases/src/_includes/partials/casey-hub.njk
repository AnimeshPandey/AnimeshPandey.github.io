{# ── casey-hub.njk ── Casey welcome panel on the hub homepage ── #}

{% set flagshipCase = null %}
{% for c in manifest.cases %}
  {% if c.flagship and c.status == 'live' %}
    {% if not flagshipCase %}{% set flagshipCase = c %}{% endif %}
  {% endif %}
{% endfor %}

<section class="casey-hub" aria-label="Casey, your Casebook guide" data-casey-hub
  {% if flagshipCase %}data-flagship-slug="{{ flagshipCase.slug }}"{% endif %}>

  <div class="casey-hub__sparkles" aria-hidden="true" data-casey-hub-sparkles>
    <span class="casey-sparkle casey-sparkle--1"></span>
    <span class="casey-sparkle casey-sparkle--2"></span>
    <span class="casey-sparkle casey-sparkle--3"></span>
    <span class="casey-sparkle casey-sparkle--4"></span>
    <span class="casey-sparkle casey-sparkle--5"></span>
  </div>

  <div class="casey-hub__avatar-wrap"
       data-casey-hub-play
       tabindex="0"
       role="button"
       aria-label="Wave at Casey, your guide">
    <span class="casey-hub__glow" aria-hidden="true"></span>
  {# One PNG in a fixed frame — no Lottie overlay (was causing double-face with pose PNGs) #}
    <div class="casey-avatar-frame casey-hub__avatar-frame" data-casey-tier="junior">
      <img class="casey-hub__img casey-avatar-frame__img"
           src="{{ '/assets/casey/junior/present.png' | url }}"
           alt="Casey, junior developer kitten, welcoming you"
           width="120" height="120"
           loading="eager"
           fetchpriority="high"
           data-casey-hub-avatar="true"
           data-casey-frame-ready="1" />
    </div>
  </div>

  <div class="casey-hub__panel">
    <p class="casey-hub__label" aria-hidden="true">
      <span data-casey-hub-tier-label>Casey · Junior dev</span>
    </p>

    <p class="casey-hub__greeting" aria-live="polite" id="casey-hub-greeting">
      Hey — pick a case below or start with the flagship. I'll hint as you scroll.
    </p>

    <ul class="casey-hub__actions" id="casey-hub-actions" role="list">
      {# Populated by casey-companion.js from progress + flagship slug #}
      {% if flagshipCase %}
      <li>
        <a href="{{ ('/' ~ flagshipCase.slug ~ '/') | url }}"
           class="casey-hub__action casey-hub__action--primary">
          Start flagship case
        </a>
      </li>
      {% endif %}
    </ul>
  </div>

</section>

{% include 'partials/casey-companion-lines.njk' %}
<script id="casey-hub-data" type="application/json">
{{ caseyHub | dump | safe }}
</script>
<script id="hub-live-cases" type="application/json">
{{ hubLiveCases | dump | safe }}
</script>
