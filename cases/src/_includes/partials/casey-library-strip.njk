{# ── Casey on /library/ — read pose, tone-aware copy ── #}
<section class="casey-library" aria-label="Casey, reading library guide" data-casey-library>
  <div class="casey-library__avatar-wrap">
    <div class="casey-avatar-frame casey-library__avatar-frame" data-casey-tier="junior">
      <img class="casey-library__img casey-avatar-frame__img"
           src="{{ '/assets/casey/junior/read.png' | url }}?v=__AP_BUILD_ID__"
           alt="Casey with a book, ready to help you browse"
           width="72" height="72"
           loading="lazy"
           data-casey-library-avatar="true"
           data-casey-frame-ready="1" />
    </div>
  </div>
  <div class="casey-library__panel">
    <p class="casey-library__label" data-casey-library-tier-label>Casey · Junior dev</p>
    <p class="casey-library__line" id="casey-library-line" aria-live="polite">
      {{ caseyLibrary.lines.junior }}
    </p>
    <a href="{{ '/index.html' | url }}" class="casey-library__link">← Back to interactive cases</a>
  </div>
</section>
<script id="casey-library-data" type="application/json">{{ caseyLibrary | dump | safe }}</script>
