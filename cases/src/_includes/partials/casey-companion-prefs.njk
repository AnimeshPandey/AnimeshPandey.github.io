{# Casey settings panel — tier, intensity, progress (Casebook header + mobile nav).
   Included twice per page (desktop header dropdown + mobile nav sheet), so every
   id/aria-labelledby pair is namespaced with panelIdPrefix to avoid duplicate IDs. #}
{% set idp = panelIdPrefix | default('') %}
<div class="casey-panel" data-casey-prefs-root data-casey-panel>
  <div class="casey-panel__header">
    <div class="casey-avatar-frame casey-panel__avatar-frame" data-casey-panel-avatar-wrap>
      <img class="casey-avatar-frame__img casey-panel__avatar"
           src="{{ '/assets/casey/junior/idle.png' | url }}?v=__AP_BUILD_ID__"
           width="48" height="48"
           alt=""
           data-casey-panel-avatar
           data-casey-frame-ready="1" />
    </div>
    <p class="casey-panel__title" data-casey-panel-tier-label>Casey · Junior dev</p>
  </div>

  <section class="casey-panel__section" aria-labelledby="{{ idp }}casey-panel-tier-heading">
    <h3 class="casebook-prefs__label" id="{{ idp }}casey-panel-tier-heading">Reading level</h3>
    <div class="casey-panel__tier case-tone" role="radiogroup" aria-label="Reading level">
      <button type="button" class="case-tone__btn casey-panel__tier-btn" role="radio" data-casey-panel-tier="junior" aria-checked="true">Junior</button>
      <button type="button" class="case-tone__btn casey-panel__tier-btn" role="radio" data-casey-panel-tier="mid" aria-checked="false">Mid</button>
      <button type="button" class="case-tone__btn casey-panel__tier-btn" role="radio" data-casey-panel-tier="staff" aria-checked="false">Staff</button>
    </div>
  </section>

  <section class="casey-panel__section" aria-labelledby="{{ idp }}casey-panel-intensity-heading">
    <h3 class="casebook-prefs__label" id="{{ idp }}casey-panel-intensity-heading">Guide intensity</h3>
    <div class="casebook-prefs__group" role="radiogroup" aria-label="Casey intensity">
      <button type="button" class="casebook-prefs__menu casey-panel__intensity" role="radio" data-casey-intensity="full" aria-checked="true">Full — hints, motion, voice</button>
      <button type="button" class="casebook-prefs__menu casey-panel__intensity" role="radio" data-casey-intensity="quiet" aria-checked="false">Quiet — no rotation or confetti</button>
      <button type="button" class="casebook-prefs__menu casey-panel__intensity" role="radio" data-casey-intensity="off" aria-checked="false">Off — avatar only</button>
    </div>
  </section>

  <section class="casey-panel__section" aria-labelledby="{{ idp }}casey-panel-progress-heading">
    <h3 class="casebook-prefs__label" id="{{ idp }}casey-panel-progress-heading">Your path</h3>
    <p class="casey-panel__progress" data-casey-panel-progress>0 of 31 live cases completed</p>
    <ul class="casey-prefs-milestones" data-casey-milestones aria-label="Your Casey milestones"></ul>
  </section>

  <div class="casey-panel__footer">
    <a class="casebook-prefs__link" href="{{ '/about/' | url }}#casey">About Casey</a>
    <button type="button" class="casebook-prefs__link casey-panel__reset" data-casey-reset>Reset memory</button>
  </div>
</div>
