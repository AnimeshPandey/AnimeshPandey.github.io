{# ── head-seo.njk ── meta, canonical, OG, JSON-LD ── #}
{% set pageTitle = title + ' · ' + site.name if title else site.name %}
{% set pageDesc = description if description else site.subtitle %}
{% set pageCanonical = site.url + (slug + '/' if slug else '') %}
{% set pageOgImage = ogImage if ogImage else site.origin + '/brand/themes/casey-share-premium.png' %}

<title>{{ pageTitle }}</title>
<meta name="description" content="{{ pageDesc }}" />
<link rel="canonical" href="{{ pageCanonical }}" />

{# ── Open Graph ── #}
<meta property="og:site_name" content="{{ site.name }}" />
<meta property="og:title" content="{{ pageTitle }}" />
<meta property="og:description" content="{{ pageDesc }}" />
<meta property="og:url" content="{{ pageCanonical }}" />
<meta property="og:image" content="{{ pageOgImage }}" />
<meta property="og:image:alt" content="{{ title | default(site.name) }} — Casey guide, The Frontend Casebook" />
<meta property="og:type" content="{{ 'article' if layout == 'layouts/case-layout.njk' else 'website' }}" />
{% if publishedAt %}
  <meta property="article:published_time" content="{{ publishedAt }}" />
{% endif %}

{# ── Twitter ── #}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="{{ site.twitter | default('@anmshpndy') }}" />
<meta name="twitter:title" content="{{ pageTitle }}" />
<meta name="twitter:description" content="{{ pageDesc }}" />
<meta name="twitter:image" content="{{ pageOgImage }}" />
<meta name="twitter:image:alt" content="{{ title | default(site.name) }} — The Frontend Casebook" />

{# ── Icons & manifest: from portfolio root, not /cases/ ── #}
<link rel="icon" type="image/svg+xml" href="/brand/casebook-favicon.svg" />
<link rel="manifest" href="/site.webmanifest" />

{% include 'partials/platform-fonts.njk' %}

{# ── Keywords (case pages only — built from principle + track + outcomes) ── #}
{% if schemaType == 'Article' %}
  {%- set _kw = [] -%}
  {%- if principle %}{% set _kw = (_kw.push(principle), _kw) %}{% endif -%}
  {%- if track %}{% set _kw = (_kw.push(track | replace('-', ' ')), _kw) %}{% endif -%}
  {%- set _kw = (_kw.push('frontend engineering'), _kw) -%}
  {%- set _kw = (_kw.push('case study'), _kw) -%}
  {%- set _kw = (_kw.push('JavaScript'), _kw) -%}
  {%- set _kw = (_kw.push(site.name), _kw) -%}
  <meta name="keywords" content="{{ _kw | join(', ') }}" />
{% endif %}

{# ── Robots ── #}
{% if noindex %}
  <meta name="robots" content="noindex, follow" />
{% else %}
  <meta name="robots" content="index, follow" />
{% endif %}

{% if site.googleVerification %}
<meta name="google-site-verification" content="{{ site.googleVerification }}" />
{% endif %}

{# ── JSON-LD ── #}
{% if schemaType == 'WebSite' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "{{ site.name }}",
  "url": "{{ site.url }}",
  "description": "{{ site.tagline }}",
  "inLanguage": "en",
  "author": {
    "@type": "Person",
    "name": "{{ site.author.name }}",
    "url": "{{ site.author.url }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.origin }}/brand/casebook-favicon.svg"
    }
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ site.url }}library/?category={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "{{ site.name }} — Interactive Cases",
  "description": "{{ site.tagline }}",
  "url": "{{ site.url }}",
  "numberOfItems": {{ collections.liveCases | length }},
  "itemListElement": [
    {% for case in collections.liveCases %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "name": "{{ case.title | escape }}",
      "url": "{{ site.url }}{{ case.slug }}/"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% elif schemaType == 'Article' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LearningResource",
  "name": "{{ title }}",
  "description": "{{ pageDesc }}",
  "url": "{{ pageCanonical }}",
  "learningResourceType": "Interactive case study",
  "educationalLevel": "beginner to advanced",
  "teaches": "{{ principle | default('') }}",
  "about": {
    "@type": "Thing",
    "name": "{{ principle | default(title) }}"
  },
  "keywords": "{{ principle | default('') }}, {{ track | replace('-', ' ') if track else '' }}, frontend engineering, JavaScript",
  "inLanguage": "en",
  "isAccessibleForFree": true,
  "author": {
    "@type": "Person",
    "name": "{{ site.author.name }}",
    "url": "{{ site.author.url }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.origin }}/brand/casebook-favicon.svg"
    }
  },
  "datePublished": "{{ publishedAt | default('') }}",
  "dateModified": "{{ publishedAt | default('') }}",
  "image": "{{ pageOgImage }}"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "{{ site.shortName }}",
      "item": "{{ site.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ track | replace('-', ' ') | title if track else 'Case studies' }}",
      "item": "{{ site.url }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ title }}",
      "item": "{{ pageCanonical }}"
    }
  ]
}
</script>
{% elif schemaType == 'AboutPage' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "{{ title }}",
  "description": "{{ pageDesc }}",
  "url": "{{ pageCanonical }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.author.name }}",
    "url": "{{ site.author.url }}"
  }
}
</script>
{% endif %}
