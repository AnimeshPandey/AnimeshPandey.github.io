{# ── case-tone-switcher.njk ── Reading level segmented control ── #}
<div class="case-tone" role="group" aria-label="Reading level" id="case-tone-switcher">
  <p class="case-tone__label visually-hidden">Reading level</p>
  <button type="button" class="case-tone__btn" data-tone="junior" aria-pressed="true">Junior</button>
  <button type="button" class="case-tone__btn" data-tone="mid"    aria-pressed="false">Mid</button>
  <button type="button" class="case-tone__btn" data-tone="staff"  aria-pressed="false">Staff</button>
</div>
