<!DOCTYPE html>
<html lang="{{ site.locale | default('en') }}"
      data-theme="high-contrast"
      data-asset-base="{{ '/assets/casey/' | url }}"
      data-path-prefix="{{ site.pathPrefix | default('/cases/') }}"
      data-ap-build-id="__AP_BUILD_ID__">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

  {# ── FOUC guard: apply stored theme before CSS loads ── #}
  <script>
  (function () {
    var valid = { light:1, dark:1, sage:1, slate:1, dusk:1, 'high-contrast':1 };
    var stored;
    try { stored = localStorage.getItem('theme'); } catch (e) {}
    document.documentElement.dataset.theme = (stored && valid[stored]) ? stored : 'high-contrast';
  })();
  </script>

  {# ── SEO partial ── #}
  {% include 'partials/head-seo.njk' %}

  {# ── Styles: portfolio foundation tokens → casebook ── #}
  {# foundation.css, theme.css, chrome.css live at the portfolio root (/assets/) #}
  {% set productStylesheet = '/assets/css/casebook.css?v=__AP_BUILD_ID__' | url %}
  {% include 'partials/platform-shell-styles.njk' %}

  {# ── Hub-only styles (hub, library, companies pages) ── #}
  {% if hubStyles %}
  <link rel="stylesheet" href="{{ '/assets/css/hub-filters.css' | url }}" />
  {% endif %}

  {# ── RSS alternate ── #}
  <link rel="alternate" type="application/rss+xml"
        title="{{ site.name }} — RSS"
        href="{{ '/feed.xml' | url }}" />

  {# ── meta theme-color (updated by theme.js) ── #}
  <meta name="theme-color" content="#000000" id="casebook-theme-color" />

  {# ── CaseyGuide: make line data available to casey-guide.js ── #}
  <script>window.__GUIDE_LINES = {{ guideLines | dump | safe }};</script>
</head>
<body class="platform-body platform-body--casebook">
  {% include 'partials/icon-sprite-nav.njk' %}
  <a href="#main" class="platform-skip casebook-skip">Skip to story</a>

  {% set product = 'casebook' %}
  {% set showRecruiter = false %}
  {% set navActive = navActive | default('') %}
  {% include 'partials/platform-header.njk' %}

  {# ── Main content slot ── #}
  <main id="main" tabindex="-1">
    {{ content | safe }}
  </main>

  {# ── Footer ── #}
  <footer class="casebook-footer" role="contentinfo">
    <p>
      <a href="{{ '/' | url }}">The Frontend Casebook</a>
      &nbsp;·&nbsp;
      <a href="{{ '/whats-new/' | url }}">What's New</a>
      &nbsp;·&nbsp;
      <a href="/">Animesh Pandey</a>
      &nbsp;·&nbsp;
      <a href="{{ '/feed.xml' | url }}" type="application/rss+xml">RSS</a>
    </p>
    <p class="case-format-credit">
      Story format inspired by
      <a href="https://growth.design/case-studies/" rel="noopener noreferrer">Growth.Design case studies</a>.
    </p>
  </footer>

  {# ── Back-to-top button ── #}
  <button class="casebook-back-top" id="casebook-back-top" aria-label="Back to top" hidden>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 12V4M8 4L4 8M8 4l4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <script>
  (function () {
    var btn = document.getElementById('casebook-back-top');
    if (!btn) return;
    btn.hidden = false;
    var show = false;
    function onScroll() {
      var s = window.scrollY > 400;
      if (s !== show) { show = s; btn.classList.toggle('visible', s); }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    btn.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });
  })();
  </script>

  {# ── Scroll-reveal for hub cards ── #}
  <script>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    var cards = document.querySelectorAll('.casebook-hub__grid .case-card-reveal, .casebook-hub__grid > li');
    if (!cards.length) return;
    var mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (mq.matches) return;
    cards.forEach(function (el) { el.classList.add('case-card-reveal'); });
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -32px 0px' });
    cards.forEach(function (el) { io.observe(el); });
  })();
  </script>

  {# ── Deferred scripts ── #}
  <script src="{{ '/assets/js/casey-guide.js' | url }}" defer></script>
  <script src="/assets/platform/chrome.js" defer></script>
  <script src="/assets/platform/prefs-chrome.js" defer></script>
  <script src="/assets/nav.js" defer></script>
  <script src="/assets/theme.js" defer></script>
  <script src="/assets/i18n/i18n.js" defer></script>
  <script src="/assets/platform/display-menu.js" defer></script>
  <script src="{{ '/assets/js/casebook-preferences.js' | url }}" defer></script>
  <script src="{{ '/assets/js/casey-companion-prefs.js' | url }}" defer></script>
  <script src="{{ '/assets/js/casebook-auth-core.js' | url }}" defer></script>
  <script src="{{ '/assets/js/casebook-auth.js' | url }}" defer></script>
  <script src="{{ '/assets/js/pro-gate.js' | url }}" defer></script>
</body>
</html>
