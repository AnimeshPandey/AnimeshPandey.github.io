<!DOCTYPE html>
<html lang="{{ site.locale | default('en') }}"
      data-casebook-color="light"
      data-casebook-contrast="high"
      data-asset-base="{{ '/assets/casey/' | url }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

  {# ── FOUC guard: apply stored casebook-color + contrast before CSS loads ── #}
  <script>
  (function () {
    var COLOR_KEY = 'casebook-color-mode';
    var CONTRAST_KEY = 'casebook-contrast';
    var stored = 'system';
    try { stored = localStorage.getItem(COLOR_KEY) || 'system'; } catch (e) {}
    if (stored === 'system') {
      try {
        var pt = localStorage.getItem('theme') || '';
        if (pt === 'dark' || pt === 'slate' || pt === 'dusk' || pt === 'high-contrast') stored = 'dark';
      } catch (e) {}
    }
    var dark = stored === 'dark' ||
      (stored === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    document.documentElement.dataset.casebookColor = dark ? 'dark' : 'light';
    var contrast = 'high';
    try { contrast = localStorage.getItem(CONTRAST_KEY) || 'high'; } catch (e) {}
    document.documentElement.dataset.casebookContrast = contrast === 'normal' ? 'normal' : 'high';
  })();
  </script>

  {# ── SEO partial ── #}
  {% include 'partials/head-seo.njk' %}

  {# ── Styles: portfolio foundation tokens → casebook ── #}
  {# foundation.css, theme.css, chrome.css live at the portfolio root (/assets/) #}
  <link rel="stylesheet" href="/assets/styles/foundation.css" />
  <link rel="stylesheet" href="/assets/theme.css" />
  <link rel="stylesheet" href="/assets/platform/chrome.css" />
  <link rel="stylesheet" href="/assets/platform/prefs-chrome.css" />
  <link rel="stylesheet" href="{{ '/assets/css/casebook.css' | url }}" />

  {# ── RSS alternate ── #}
  <link rel="alternate" type="application/rss+xml"
        title="{{ site.name }} — RSS"
        href="{{ '/feed.xml' | url }}" />

  {# ── meta theme-color (updated by casebook-preferences.js) ── #}
  <meta name="theme-color" content="#FAF8F4" id="casebook-theme-color" />
</head>
<body class="platform-body platform-body--casebook">
  {% include 'partials/icon-sprite-nav.njk' %}
  <a href="#main" class="platform-skip casebook-skip">Skip to story</a>

  {% set product = 'casebook' %}
  {% set showRecruiter = false %}
  {% set navActive = navActive | default('') %}
  {% include 'partials/platform-header.njk' %}

  {# ── Main content slot ── #}
  <main id="main" tabindex="-1">
    {{ content | safe }}
  </main>

  {# ── Footer ── #}
  <footer class="casebook-footer" role="contentinfo">
    <p>
      <a href="{{ '/' | url }}">The Frontend Casebook</a>
      &nbsp;·&nbsp;
      <a href="/">Animesh Pandey</a>
      &nbsp;·&nbsp;
      <a href="{{ '/feed.xml' | url }}" type="application/rss+xml">RSS</a>
    </p>
    <p class="case-format-credit">
      Story format inspired by
      <a href="https://growth.design/case-studies/" rel="noopener noreferrer">Growth.Design case studies</a>.
    </p>
  </footer>

  {# ── Deferred scripts ── #}
  <script src="/assets/platform/chrome.js" defer></script>
  <script src="/assets/platform/prefs-chrome.js" defer></script>
  <script src="/assets/platform/theme-bridge.js" defer></script>
  <script src="/assets/platform/display-menu.js" defer></script>
  <script src="{{ '/assets/js/casebook-preferences.js' | url }}" defer></script>
</body>
</html>
