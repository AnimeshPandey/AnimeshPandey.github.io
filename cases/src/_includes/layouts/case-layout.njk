---
layout: layouts/casebook-layout.njk
---
{# ── Progress bar ── #}
<div class="casebook-progress" id="casebook-progress" aria-hidden="true"></div>

<div class="casebook-case">
  {# ── Main story column ── #}
  <article class="case-scroll" role="article" data-pagefind-body>
    {# ── Breadcrumb ── #}
    {% include 'partials/case-header.njk' %}

    {# ── Cover ── #}
    {% set nav = slug | caseNav %}
    <header class="case-cover">
      <p class="case-cover__track">{{ track | replace("-", " ") | title }}</p>
      <h1 class="case-cover__title">{{ title }}</h1>
      <div class="case-cover__meta">
        {# Same real "No. 0NN" live-case position shown on the hub card
           (case-navigation.js's liveIndex) — carries the case-file identity
           from the hub grid onto the case's own page. #}
        {% if nav %}
          <span class="case-cover__stamp">No. {{ nav.liveIndex | pad3 }}</span>
        {% endif %}
        {# Real reading time, computed at build time from this case's actual
           default-tone prose (cases/.eleventy.js's caseReadingStats), not
           the hand-typed readMin front-matter field — same idiom as the
           hub card's "Nm", sourced from the same computed value. #}
        {% set readStats = caseReadingStats[slug] %}
        {% if readStats %}
          <span id="case-reading-time" title="{{ readStats.words }} words, measured from this case's actual prose">{{ readStats.minutes }} min read</span>
        {% else %}
          <span id="case-reading-time">{{ readMin | default(10) }} min read</span>
        {% endif %}
        {% if publishedAt %}
          <span>· {{ publishedAt | readableDate }}</span>
        {% endif %}
        {# Real, git-derived "last updated" date (design-backlog idea #27) —
           the actual last-commit date of this case's own content file
           (cases/.eleventy.js's caseLastUpdated, cases/lib/git-dates.js),
           not a guess. Only rendered when git history was actually
           available at build time (see git-dates.js) so an unavailable
           date is simply omitted rather than shown as a wrong one. #}
        {% set lastUpdated = caseLastUpdated[slug] %}
        {% if lastUpdated and lastUpdated != publishedAt %}
          <span title="Real last-commit date for this case's content file">· Updated {{ lastUpdated | readableDate }}</span>
        {% endif %}
        {# Real "what you'll teach yourself" principle (design-backlog idea #25)
           — the same front-matter `principle` field already feeding this page's
           SEO keywords/JSON-LD (partials/head-seo.njk) but, until now, never
           shown to an actual reader. Real per-case fact, not a generic label. #}
        {% if principle %}
          <span class="case-cover__badge">{{ principle }}</span>
        {% endif %}
        {# Real demo-type tag (design-backlog idea #23) — same `demoType` field
           and same ⚡/▶ icon convention already used inside the demo chapter
           itself (partials/case-demo-shell.njk), surfaced here so a reader
           knows before scrolling whether the case ends in an animation or an
           interactive toggle demo. #}
        {% if demoType %}
          <span class="case-cover__badge">{% if demoType == 'animation' %}⚡ Animation demo{% else %}▶ Interactive demo{% endif %}</span>
        {% endif %}
        {% if flagship %}
          <span class="case-cover__badge">★ Flagship</span>
        {% endif %}
      </div>
    </header>

    {# ── Tone switcher ── #}
    {% include 'partials/case-tone-switcher.njk' %}

    {# ── Case content (chapters from per-case index.njk) ── #}
    {{ content | safe }}

    {# ── Share ── #}
    {% include 'partials/case-share.njk' %}

    {# ── Continue / next case + progression ── #}
    {% include 'partials/case-continue.njk' %}

    {# ── Related cases ── #}
    {% include 'partials/case-related.njk' %}

    {# ── Subscribe CTA ── #}
    {% include 'partials/subscribe-cta.njk' %}

    {# ── Footer credit ── #}
    {% include 'partials/case-footer.njk' %}
  </article>

  {# ── Casey coach aside (desktop) ── #}
  <aside aria-label="Casey your guide" class="casey-coach">
    {% set caseyIdPrefix = "" %}
    {% include 'partials/casey-coach.njk' %}
  </aside>
</div>

{# ── Casey coach dock (mobile) ── #}
<div class="casey-coach casey-coach--dock-bottom" aria-label="Casey your guide (dock)" id="casey-dock">
  {% set caseyIdPrefix = "mobile-" %}
  {% include 'partials/casey-coach.njk' %}
</div>

{# ── Case scripts ── #}
{# Inline casey data for JS #}
<script type="application/json" id="casey-data">{{ caseyData | jsonLd | safe }}</script>

{% include 'partials/casey-companion-lines.njk' %}
<script src="{{ '/assets/js/casey-companion.js' | url }}" defer></script>
<script src="{{ '/assets/js/casebook-auth-core.js' | url }}" defer></script>
<script src="{{ '/assets/js/casebook-auth.js' | url }}" defer></script>
<script src="{{ '/assets/js/casebook-progression.js' | url }}" defer></script>
<script src="{{ '/assets/js/case-continue.js' | url }}" defer></script>
<script src="{{ '/assets/js/casebook-tone.js' | url }}" defer></script>
<script src="{{ '/assets/js/case-scroll.js' | url }}" defer></script>
<script src="{{ '/cases/assets/js/chapter-progress.js' | url }}" defer></script>
<script src="{{ '/assets/js/casey-coach.js' | url }}" defer></script>
<script type="module" src="{{ '/assets/js/casey-voice.js' | url }}"></script>
<script type="module" src="{{ '/assets/js/demo-loader.js' | url }}"></script>
