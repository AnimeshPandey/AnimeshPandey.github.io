---
layout: layouts/casebook-layout.njk
navActive: cases
title: The Frontend Casebook
description: Visual case studies for frontend and agent UI engineering. Scroll through the patterns production UIs teach you — with Casey as your guide.
schemaType: WebSite
ogImage: https://anmshpndy.com/brand/themes/casey-share-premium.png
hubStyles: true
permalink: /index.html
---

<div class="casebook-hub">

  {# ── Hero + Casey (side-by-side on wide screens) ── #}
  <div class="casebook-hub__hero-stage">
    <header class="casebook-hub__hero">
      <h1 class="casebook-hub__title">The Frontend Casebook</h1>
      <p class="casebook-hub__subtitle">{{ site.tagline }}</p>
    </header>

    {% include 'partials/casey-hub.njk' %}
  </div>

  {# ── Browse toolbar: content type + track filter ── #}
  <section class="hub-toolbar" aria-label="Browse cases">
    <div class="hub-toolbar__type" role="group" aria-label="Content type">
      <a href="{{ '/index.html' | url }}"
         class="seg-btn seg-btn--active"
         aria-current="page">
        Interactive cases
      </a>
      <a href="{{ '/library/' | url }}"
         class="seg-btn">
        Reading library
        <span class="seg-btn__count" aria-label="{{ libraryEntries | length }} articles">{{ libraryEntries | length }}</span>
      </a>
    </div>

    <div class="hub-toolbar__card">
      <div class="hub-toolbar__main">
        <div class="hub-toolbar__field">
          <label for="track-filter" class="hub-toolbar__label">Track</label>
          <select id="track-filter" class="hub-select hub-toolbar__select"
                  aria-controls="hub-grid hub-grid-empty">
            <option value="">All tracks — live cases</option>
            {% set tracks = [] %}
            {% for c in manifest.cases %}
              {% if c.track not in tracks %}
                {% set tracks = (tracks.push(c.track), tracks) %}
                <option value="{{ c.track }}">{{ c.track | replace("-", " ") | title }}</option>
              {% endif %}
            {% endfor %}
          </select>
        </div>
        <div class="hub-toolbar__status" aria-live="polite" aria-atomic="true">
          <span class="hub-toolbar__count" id="hub-filter-count"></span>
          <button type="button" class="hub-toolbar__clear" id="hub-clear-filter" hidden>
            Clear filter
          </button>
        </div>
      </div>
      <div class="hub-toolbar__footer" id="hub-upcoming-toggle" hidden>
        <button type="button" class="hub-toolbar__upcoming" id="hub-show-upcoming" aria-expanded="false">
          <span class="hub-toolbar__upcoming-label">Show upcoming cases</span>
          <span class="hub-toolbar__upcoming-count" id="hub-upcoming-count"></span>
        </button>
      </div>
    </div>
  </section>

  {# ── Progress strip — between toolbar and grid ── #}
  {% include 'partials/hub-progress-strip.njk' %}

  {# ── Case catalog (grid or empty state, never both) ── #}
  <div class="hub-catalog" id="hub-catalog">
  <ul class="casebook-hub__grid" id="hub-grid" role="list">
    {% set liveTally = [] %}
    {% for case in manifest.cases %}
      {% set isLive = case.status == 'live' %}
      {% set isScheduled = case.status == 'scheduled' %}
      {# Case No. is this case's real position among live/published cases, in
         the same order the grid renders them — not a decorative fake number. #}
      {% if isLive %}
        {% set liveTally = (liveTally.push(1), liveTally) %}
        {% set caseNo = liveTally.length %}
      {% endif %}

      <li data-track="{{ case.track }}"
          data-status="{{ case.status }}"
          {% if case.publishedAt %}data-published-at="{{ case.publishedAt }}"{% endif %}>

        {% if isLive %}
          <a href="{{ ('/' ~ case.slug ~ '/') | url }}"
             class="case-card__link">
            <article class="case-card" aria-label="{{ case.title }}">
              <span class="case-card__stamp">No. {{ caseNo | pad3 }}</span>
        {% elif isScheduled %}
          <article class="case-card case-card--scheduled"
                   aria-label="{{ case.title }} — Scheduled"
                   aria-disabled="true">
        {% else %}
          <article class="case-card case-card--soon"
                   aria-label="{{ case.title }} — Coming soon"
                   aria-disabled="true">
        {% endif %}

              <p class="case-card__track">{{ case.track | replace("-", " ") | title }}</p>
              <h2 class="case-card__title">{{ case.title }}</h2>
              <div class="case-card__meta">
                {% if case.flagship %}
                  <span class="case-card__badge case-card__badge--flagship">★ Flagship</span>
                {% endif %}
                {% if case.mvpLaunch and isLive %}
                  <span id="mvp-badge-desc-{{ case.slug }}" class="visually-hidden">MVP launch case with references, interactive demo, and Casey coach polish.</span>
                  <span class="case-card__badge case-card__badge--mvp" title="MVP launch — references, demo, and Casey polish" aria-describedby="mvp-badge-desc-{{ case.slug }}">MVP</span>
                {% endif %}
                {% if case.tier == 'pro' %}
                  <span class="case-card__badge case-card__badge--pro" title="Pro depth — full access coming soon">🔒 Pro</span>
                {% endif %}
                {# "New" badge is injected by JS from data-published-at — no server-side guess #}
                {% if isScheduled %}
                  <span class="case-card__badge case-card__badge--scheduled">Coming soon</span>
                {% elif not isLive and not isScheduled %}
                  <span class="case-card__badge case-card__badge--soon">Coming soon</span>
                {% endif %}
                <span class="case-card__read">{{ case.readMin }}m</span>
              </div>

        {% if isLive %}
            </article>
          </a>
        {% else %}
          </article>
        {% endif %}
      </li>
    {% endfor %}
  </ul>

  <div class="hub-empty" id="hub-grid-empty" hidden aria-live="polite">
    <div class="casey-avatar-frame hub-empty__avatar" data-casey-tier="junior">
      <img class="hub-empty__img casey-avatar-frame__img"
           src="{{ '/assets/casey/junior/curious.png' | url }}?v=__AP_BUILD_ID__"
           alt="Casey — no cases match this filter"
           width="80" height="80"
           loading="lazy"
           data-casey-empty-avatar="true"
           data-casey-frame-ready="1" />
    </div>
    <p class="hub-empty__msg">No live cases in this track yet.</p>
    <button type="button" class="casey-hub__action hub-empty__clear" id="hub-empty-clear">
      Clear track filter
    </button>
  </div>
  </div>

  {# ── Subscribe CTA — after grid so user has context ── #}
  {% include 'partials/subscribe-cta.njk' %}

</div>

<script>
(function () {
  var sel = document.getElementById('track-filter');
  var grid = document.getElementById('hub-grid');
  var catalog = document.getElementById('hub-catalog');
  var countEl = document.getElementById('hub-filter-count');
  var clearBtn = document.getElementById('hub-clear-filter');
  var emptyClearBtn = document.getElementById('hub-empty-clear');
  var emptyEl = document.getElementById('hub-grid-empty');

  var upcomingToggle = document.getElementById('hub-upcoming-toggle');
  var showUpcomingBtn = document.getElementById('hub-show-upcoming');
  var upcomingCountEl = document.getElementById('hub-upcoming-count');
  var upcomingVisible = false;
  var upcomingItems = [];

  function clearTrackFilter() {
    if (!sel) return;
    sel.value = '';
    filter();
  }

  if (clearBtn) clearBtn.addEventListener('click', clearTrackFilter);
  if (emptyClearBtn) emptyClearBtn.addEventListener('click', clearTrackFilter);

  if (grid) {
    var nonLiveItems = Array.from(
      grid.querySelectorAll('[data-status]:not([data-status="live"]):not([data-status="scheduled"])')
    );
    var scheduledItems = Array.from(grid.querySelectorAll('[data-status="scheduled"]'));
    upcomingItems = nonLiveItems.concat(scheduledItems);

    if (upcomingItems.length > 0) {
      upcomingItems.forEach(function (item) { item.hidden = true; });
      if (upcomingToggle) {
        upcomingToggle.hidden = false;
        if (upcomingCountEl) upcomingCountEl.textContent = String(upcomingItems.length);
      }
      if (showUpcomingBtn) {
        showUpcomingBtn.addEventListener('click', function () {
          upcomingVisible = !upcomingVisible;
          upcomingItems.forEach(function (item) { item.hidden = !upcomingVisible; });
          showUpcomingBtn.setAttribute('aria-expanded', String(upcomingVisible));
          var label = showUpcomingBtn.querySelector('.hub-toolbar__upcoming-label');
          if (label) {
            label.textContent = upcomingVisible ? 'Hide upcoming cases' : 'Show upcoming cases';
          }
          if (upcomingCountEl) {
            upcomingCountEl.hidden = upcomingVisible;
          }
          filter();
        });
      }
    }
  }

  function annotateTrackOptions() {
    if (!sel || !grid) return;
    var liveByTrack = {};
    grid.querySelectorAll('[data-status="live"]').forEach(function (item) {
      var t = item.dataset.track;
      if (t) liveByTrack[t] = (liveByTrack[t] || 0) + 1;
    });
    Array.from(sel.options).forEach(function (opt) {
      if (!opt.value) return;
      var n = liveByTrack[opt.value] || 0;
      var base = opt.textContent.replace(/\s*\(\d+\)\s*$/, '');
      opt.textContent = base + ' (' + n + ')';
    });
  }

  function filter() {
    if (!sel || !grid) return;
    var track = sel.value;
    var items = grid.querySelectorAll('[data-track]');
    var visible = 0;
    var liveVisible = 0;
    items.forEach(function (item) {
      var trackMatch = !track || item.dataset.track === track;
      var statusMatch = item.dataset.status === 'live' || upcomingVisible;
      var show = trackMatch && statusMatch;
      item.hidden = !show;
      if (show) {
        visible++;
        if (item.dataset.status === 'live') liveVisible++;
      }
    });

    var showEmpty = !!track && liveVisible === 0;
    if (emptyEl) emptyEl.hidden = !showEmpty;
    if (grid) grid.hidden = showEmpty;
    if (catalog) catalog.classList.toggle('hub-catalog--empty', showEmpty);

    if (countEl) {
      if (!track) {
        countEl.textContent = liveVisible + ' live';
      } else {
        countEl.textContent = liveVisible + ' in this track';
      }
    }
    if (clearBtn) clearBtn.hidden = !track;

    document.dispatchEvent(new CustomEvent('casey-hub-filter', {
      detail: { count: liveVisible, track: track || null }
    }));
  }

  if (sel) {
    annotateTrackOptions();
    sel.addEventListener('change', filter);
    filter();
  }

  // ── "New" badge — client-side date math ──────────────────────
  var newDays = parseInt(grid && grid.dataset.newDays, 10) || 14;
  var cutoff = Date.now() - newDays * 24 * 60 * 60 * 1000;
  var liveItems = document.querySelectorAll('#hub-grid [data-status="live"][data-published-at]');
  liveItems.forEach(function (li) {
    var pub = new Date(li.dataset.publishedAt).getTime();
    if (!isNaN(pub) && pub >= cutoff) {
      var meta = li.querySelector('.case-card__meta');
      if (!meta) return;
      var badge = document.createElement('span');
      badge.className = 'case-card__badge case-card__badge--new';
      badge.textContent = 'New';
      var flagship = meta.querySelector('.case-card__badge--flagship');
      if (flagship && flagship.nextSibling) {
        meta.insertBefore(badge, flagship.nextSibling);
      } else {
        meta.insertBefore(badge, meta.firstChild);
      }
    }
  });
}());
</script>

<script id="manifest-slug-order" type="application/json">[{% for c in manifest.cases %}"{{ c.slug }}"{% if not loop.last %},{% endif %}{% endfor %}]</script>
<script id="hub-case-titles" type="application/json">{{ hubCaseTitles | jsonLd | safe }}</script>
<script src="{{ '/assets/js/casey-companion.js' | url }}" defer></script>
<script src="{{ '/assets/js/casebook-auth.js' | url }}" defer></script>
<script src="{{ '/assets/js/casebook-progression.js' | url }}" defer></script>
<script src="{{ '/assets/js/casey-hub.js' | url }}" defer></script>
