---
layout: layouts/casebook-layout.njk
navActive: cases
title: The Frontend Casebook
description: Visual case studies for frontend and agent UI engineering. Scroll through the patterns production UIs teach you — with Casey as your guide.
schemaType: WebSite
permalink: /index.html
---

<div class="casebook-hub">

  {# ── Hero ── #}
  <header class="casebook-hub__hero">
    <h1 class="casebook-hub__title">The Frontend Casebook</h1>
    <p class="casebook-hub__subtitle">{{ site.tagline }}</p>
    <p class="casebook-hub__stats">
      {{ manifest.stats.total }} cases across 18 tracks ·
      <a href="{{ '/about/' | url }}">About this project</a>
    </p>
  </header>

  {# ── Subscribe CTA ── #}
  {% include 'partials/subscribe-cta.njk' %}

  {# ── Track filter ── #}
  <div class="casebook-hub__filter">
    <label for="track-filter">Filter by track</label>
    <select id="track-filter" aria-controls="hub-grid">
      <option value="">All tracks</option>
      {% set tracks = [] %}
      {% for c in manifest.cases %}
        {% if c.track not in tracks %}
          {% set tracks = (tracks.push(c.track), tracks) %}
          <option value="{{ c.track }}">{{ c.track | replace("-", " ") | title }}</option>
        {% endif %}
      {% endfor %}
    </select>
    <span class="casebook-hub__filter-count"
          id="hub-filter-count"
          aria-live="polite"
          aria-atomic="true"></span>
  </div>

  {# ── Case grid ── #}
  <ul class="casebook-hub__grid" id="hub-grid" role="list">
    {% for case in manifest.cases %}
      {% set isLive = case.status == 'live' %}
      {% set isScheduled = case.status == 'scheduled' %}

      <li data-track="{{ case.track }}"
          data-status="{{ case.status }}"
          {% if case.publishedAt %}data-published-at="{{ case.publishedAt }}"{% endif %}>

        {% if isLive %}
          <a href="{{ ('/' ~ case.slug ~ '/') | url }}"
             class="case-card__link">
            <article class="case-card" aria-label="{{ case.title }}">
        {% elif isScheduled %}
          <article class="case-card case-card--scheduled"
                   aria-label="{{ case.title }} — Scheduled"
                   aria-disabled="true">
        {% else %}
          <article class="case-card case-card--soon"
                   aria-label="{{ case.title }} — Coming soon"
                   aria-disabled="true">
        {% endif %}

              <p class="case-card__track">{{ case.track | replace("-", " ") | title }}</p>
              <h2 class="case-card__title">{{ case.title }}</h2>
              <div class="case-card__meta">
                {% if case.flagship %}
                  <span class="case-card__badge case-card__badge--flagship">★ Flagship</span>
                {% endif %}
                {# "New" badge is injected by JS from data-published-at — no server-side guess #}
                {% if isScheduled %}
                  <span class="case-card__badge case-card__badge--scheduled">Coming soon</span>
                {% elif not isLive and not isScheduled %}
                  <span class="case-card__badge case-card__badge--soon">Coming soon</span>
                {% endif %}
                <span class="case-card__read">{{ case.readMin }}m</span>
              </div>

        {% if isLive %}
            </article>
          </a>
        {% else %}
          </article>
        {% endif %}
      </li>
    {% endfor %}
  </ul>

</div>

<script>
(function () {
  // ── Track filter ──────────────────────────────────────────────
  var sel = document.getElementById('track-filter');
  var grid = document.getElementById('hub-grid');
  var count = document.getElementById('hub-filter-count');
  if (sel && grid) {
    function filter() {
      var track = sel.value;
      var items = grid.querySelectorAll('[data-track]');
      var visible = 0;
      items.forEach(function (item) {
        var show = !track || item.dataset.track === track;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      count.textContent = track ? visible + ' case' + (visible !== 1 ? 's' : '') : '';
    }
    sel.addEventListener('change', filter);
    filter();
  }

  // ── "New" badge — client-side date math ──────────────────────
  // NEW_BADGE_DAYS from site.json (baked at build time via data-new-days attr on grid,
  // or fall back to 14). No server-side guessing of "is this new?" needed.
  var newDays = parseInt(grid && grid.dataset.newDays, 10) || 14;
  var cutoff = Date.now() - newDays * 24 * 60 * 60 * 1000;
  var liveItems = document.querySelectorAll('#hub-grid [data-status="live"][data-published-at]');
  liveItems.forEach(function (li) {
    var pub = new Date(li.dataset.publishedAt).getTime();
    if (!isNaN(pub) && pub >= cutoff) {
      var meta = li.querySelector('.case-card__meta');
      if (!meta) return;
      var badge = document.createElement('span');
      badge.className = 'case-card__badge case-card__badge--new';
      badge.textContent = 'New';
      // Insert after flagship badge if present, else prepend
      var flagship = meta.querySelector('.case-card__badge--flagship');
      if (flagship && flagship.nextSibling) {
        meta.insertBefore(badge, flagship.nextSibling);
      } else {
        meta.insertBefore(badge, meta.firstChild);
      }
    }
  });
}());
</script>
