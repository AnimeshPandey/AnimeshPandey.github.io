---
layout: layouts/casebook-layout.njk
navActive: cases
title: "What's New — The Frontend Casebook"
description: "Recent updates to The Frontend Casebook — new cases, features, and content."
schemaType: WebSite
slug: whats-new
permalink: /whats-new/index.html
noindex: false
---

<main class="casebook-main" id="main-content">
  <div class="casebook-container">
    <header class="whats-new-header">
      <h1>What's new</h1>
      <p class="whats-new-subtitle">Recent cases, features, and content updates.
        &nbsp;·&nbsp;<a href="{{ '/feed.xml' | url }}" type="application/rss+xml">RSS feed</a>
      </p>
    </header>

    <ol class="whats-new-list" reversed>
    {% for entry in changelog | reverse %}
      <li class="whats-new-entry whats-new-entry--{{ entry.type }}">
        <time class="whats-new-entry__date" datetime="{{ entry.date }}">{{ entry.date | readableDate }}</time>
        <span class="whats-new-entry__badge whats-new-entry__badge--{{ entry.type }}">
          {% if entry.type == "case" %}Case{% elif entry.type == "feature" %}Feature{% else %}Update{% endif %}
        </span>
        {% if entry.slug %}
          <a class="whats-new-entry__title" href="{{ ('/' ~ entry.slug ~ '/') | url }}">{{ entry.title }}</a>
        {% else %}
          <span class="whats-new-entry__title">{{ entry.title }}</span>
        {% endif %}
      </li>
    {% endfor %}
    </ol>
  </div>
</main>
