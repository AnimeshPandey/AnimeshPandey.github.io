---
layout: layouts/casebook-layout.njk
navActive: cases
title: Companies — The Frontend Casebook
description: Browse frontend engineering articles by company. 160+ teams from Airbnb, Shopify, Stripe, and more.
noindex: true
hubStyles: true
permalink: /companies/index.html
---

<div class="casebook-hub casebook-hub--companies">

  <header class="casebook-hub__hero">
    <h1 class="casebook-hub__title">Companies</h1>
    <p class="casebook-hub__subtitle">
      {{ hubFacets.companies | length }} teams ·
      <a href="{{ '/library/' | url }}">Reading library</a> ·
      <a href="{{ '/index.html' | url }}">← Interactive cases</a>
    </p>
  </header>

  {# ── Search ── #}
  <div class="companies-search">
    <label for="company-search" class="visually-hidden">Search companies</label>
    <input type="search"
           id="company-search"
           class="combobox-input companies-search__input"
           placeholder="Search companies…"
           aria-controls="companies-list"
           autocomplete="off">
  </div>

  {# ── A-Z index ── #}
  <nav class="az-nav" aria-label="Jump to letter">
    {% set letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("") %}
    {% for letter in letters %}
      <a href="#az-{{ letter }}" class="az-nav__link">{{ letter }}</a>
    {% endfor %}
  </nav>

  {# ── Company grid ── #}
  <ul class="companies-list" id="companies-list" role="list">
    {% set currentLetter = "" %}
    {% for company in hubFacets.companies | sort(false, false, "name") %}
      {% set firstChar = company.name[0] | upper %}
      {% if firstChar != currentLetter %}
        {% set currentLetter = firstChar %}
        <li class="companies-list__letter-divider" id="az-{{ currentLetter }}" aria-hidden="true">{{ currentLetter }}</li>
      {% endif %}
      <li class="companies-list__item"
          data-name="{{ company.name | lower }}"
          data-slug="{{ company.slug }}">
        <a href="{{ ('/companies/' ~ company.slug ~ '/') | url }}"
           class="company-card">
          <span class="company-card__name">{{ company.name }}</span>
          <span class="company-card__count" aria-label="{{ company.count }} articles">
            {{ company.count }} article{{ 's' if company.count != 1 else '' }}
          </span>
          {% if company.minYear %}
            {# Real coverage span — the actual min/max publishedYear across this
               company's library entries, not a fabricated "since" date. Same
               "real number, not decoration" idiom as the case-file stamp and
               reading-card catalog number, applied here as a case-file's date
               range on its folder tab. #}
            <span class="company-card__years"
                  aria-label="{% if company.maxYear != company.minYear %}Coverage {{ company.minYear }} to {{ company.maxYear }}{% else %}Coverage in {{ company.minYear }}{% endif %}">{{ company.minYear }}{% if company.maxYear != company.minYear %}–{{ company.maxYear }}{% endif %}</span>
          {% endif %}
        </a>
      </li>
    {% endfor %}
  </ul>

</div>

<script>
(function () {
  var input = document.getElementById('company-search');
  var list = document.getElementById('companies-list');
  if (!input || !list) return;

  input.addEventListener('input', function () {
    var q = input.value.toLowerCase().trim();
    list.querySelectorAll('.companies-list__item[data-name]').forEach(function (li) {
      var match = !q || li.dataset.name.includes(q);
      li.hidden = !match;
    });
    list.querySelectorAll('.companies-list__letter-divider').forEach(function (div) {
      var nextItems = [];
      var el = div.nextElementSibling;
      while (el && !el.classList.contains('companies-list__letter-divider')) {
        if (el.dataset.name) nextItems.push(el);
        el = el.nextElementSibling;
      }
      var anyVisible = nextItems.some(function (i) { return !i.hidden; });
      div.hidden = !anyVisible;
    });
  });
}());
</script>

{% include 'partials/casey-companion-lines.njk' %}
<script src="{{ '/assets/js/casey-companion.js' | url }}" defer></script>
<script src="{{ '/assets/js/casey-companies.js' | url }}" defer></script>
