{
  "name": "anmshpndy-site-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Static contracts, unit tests, and Playwright E2E for portfolio + Casebook",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:deploy": "node scripts/build-deploy.mjs",
    "serve:deploy": "node scripts/serve-deploy.mjs",
    "test:static": "node scripts/run-static.mjs",
    "test:unit": "node --test unit/manifest-data.test.mjs unit/casebook-auth-core.test.mjs unit/case-navigation.test.mjs unit/casey-guide.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "npm run build:deploy && npm run test:static && npm run test:unit && npm run test:e2e",
    "postinstall": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1"
  }
}
